# ================================================================
# GeoAI SAM 项目 - 环境变量配置模板
# ================================================================
# 复制此文件为 .env 并填写实际值:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows)
# ================================================================

# --- SAM 模型配置 ---
# SAM 版本: sam1 / sam2 / sam3
SAM_VERSION=sam1

# SAM 模型类型: vit_b / vit_l / vit_h
# vit_b: 轻量 (2~4GB VRAM)
# vit_l: 中等 (4~8GB VRAM) <-- 6GB 显存推荐
# vit_h: 大型 (8GB+ VRAM)
SAM_MODEL_TYPE=vit_l

# 模型检查点路径 (留空则自动下载到 MODEL_DIR)
SAM_CHECKPOINT_PATH=

# 模型存放目录 (所有模型权重都下载到这里，不会使用系统 .cache)
MODEL_DIR=./models

# --- GroundingDINO 配置 ---
# GroundingDINO 模型: GroundingDINO_SwinT / GroundingDINO_SwinB
# SwinT: 轻量 (~700MB), SwinB: 更精确 (~1.5GB)
# 6GB 显存推荐 SwinT
GROUNDINGDINO_MODEL=GroundingDINO_SwinT

# 检测框置信度阈值 (0~1)
BOX_THRESHOLD=0.25

# 文本匹配置信度阈值 (0~1)
TEXT_THRESHOLD=0.25

# --- CLIP 配置 ---
# CLIP 模型: ViT-B-32 / ViT-B-16 / ViT-L-14
# ViT-B-32 最轻量，推荐 6GB 显存使用
CLIP_MODEL=ViT-B-32

# --- 运行设备 ---
# 留空则自动检测 (优先使用 GPU)
# 如果显存不足可设为 cpu
DEVICE=

# --- 输出配置 ---
OUTPUT_DIR=./output
OUTPUT_FORMAT=geojson

# --- 后处理默认参数 ---
POSTPROCESS_MIN_SIZE=200
POSTPROCESS_FILL_HOLES=true
POSTPROCESS_SMOOTH_SIGMA=1.5
POSTPROCESS_OPENING_RADIUS=2
POSTPROCESS_CLOSING_RADIUS=3

# --- 数据路径 ---
# 默认测试影像路径
DEFAULT_IMAGE=西安19级.tif

# ================================================================
# 以下由 config.py 自动设置，一般无需手动修改
# 模型缓存会统一重定向到 MODEL_DIR 下的子目录:
#   TORCH_HOME         → models/torch/
#   HF_HOME            → models/huggingface/
#   TRANSFORMERS_CACHE → models/huggingface/transformers/
#   HF_HUB_CACHE       → models/huggingface/hub/
#   CLIP_CACHE         → models/clip/
# ================================================================
